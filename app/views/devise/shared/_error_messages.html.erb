<% if resource.errors.any? %>
  <div class="error-box">
    <strong><%= pluralize(resource.errors.count, "error") %> prevented this account from being saved.</strong>
    <ul>
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
