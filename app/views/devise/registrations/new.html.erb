<section class="page-header">
  <div>
    <span class="eyebrow">Compte</span>
    <h1 class="page-title">Créer votre espace de travail</h1>
  </div>
</section>

<section class="card form-card">
  <div class="card-body">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "form-grid" }) do |form| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <%= form.label :account_name, "Nom de l'espace de travail" %>
        <%= form.text_field :account_name, autofocus: true, autocomplete: "organization" %>
      </div>

      <div class="field">
        <%= form.label :email %>
        <%= form.email_field :email, autocomplete: "email" %>
      </div>

      <div class="field">
        <%= form.label :password, "Mot de passe" %>
        <%= form.password_field :password, autocomplete: "new-password" %>
        <% if @minimum_password_length %>
          <p class="field-hint"><%= @minimum_password_length %> caractères minimum.</p>
        <% end %>
      </div>

      <div class="field">
        <%= form.label :password_confirmation, "Confirmation du mot de passe" %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <div class="actions">
        <%= form.submit "Créer le compte", class: "btn btn-primary" %>
        <%= link_to "Se connecter", new_session_path(resource_name), class: "btn" %>
      </div>
    <% end %>
  </div>
</section>
