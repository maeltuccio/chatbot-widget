<section class="page-header">
  <div>
    <span class="eyebrow">Account</span>
    <h1 class="page-title">Create your workspace</h1>
    <p class="page-description">Create an owner account to manage agents, Webflow connections, and knowledge sources.</p>
  </div>
</section>

<section class="card form-card">
  <div class="card-body">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "form-grid" }) do |form| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <%= form.label :account_name, "Workspace name" %>
        <%= form.text_field :account_name, autofocus: true, autocomplete: "organization" %>
      </div>

      <div class="field">
        <%= form.label :email %>
        <%= form.email_field :email, autocomplete: "email" %>
      </div>

      <div class="field">
        <%= form.label :password %>
        <%= form.password_field :password, autocomplete: "new-password" %>
        <% if @minimum_password_length %>
          <p class="field-hint"><%= @minimum_password_length %> characters minimum.</p>
        <% end %>
      </div>

      <div class="field">
        <%= form.label :password_confirmation %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <div class="actions">
        <%= form.submit "Create account", class: "btn btn-primary" %>
        <%= link_to "Sign in", new_session_path(resource_name), class: "btn" %>
      </div>
    <% end %>
  </div>
</section>

