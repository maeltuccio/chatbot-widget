<section class="page-header">
  <div>
    <span class="eyebrow">Backoffice</span>
    <h1 class="page-title">Sign in</h1>
    <p class="page-description">Access your workspace to manage agents, knowledge, and integrations.</p>
  </div>
</section>

<section class="card form-card">
  <div class="card-body">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "form-grid" }) do |form| %>
      <div class="field">
        <%= form.label :email %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div class="field">
        <%= form.label :password %>
        <%= form.password_field :password, autocomplete: "current-password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="check-field">
          <%= form.check_box :remember_me %>
          <%= form.label :remember_me %>
        </div>
      <% end %>

      <div class="actions">
        <%= form.submit "Sign in", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</section>
