<section class="page-header">
  <div>
    <span class="eyebrow">Utilisation</span>
    <h1 class="page-title">Tableau d'utilisation</h1>
    <p class="page-description">Suivez les réponses IA, les embeddings et les tokens consommés par cet espace de travail.</p>
  </div>

  <div class="actions">
    <%= link_to "Exporter le CSV facturable", usage_path(format: :csv), class: "btn btn-primary" %>
  </div>
</section>

<section class="stats-grid usage-stats-grid">
  <div class="stat-card">
    <strong><%= @message_usage.count %></strong>
    <span>Réponses IA ce mois-ci</span>
  </div>
  <div class="stat-card">
    <strong><%= number_with_delimiter(@message_usage.sum(:total_tokens)) %></strong>
    <span>Tokens des messages</span>
  </div>
  <div class="stat-card">
    <strong><%= @embedding_usage.count %></strong>
    <span>Embeddings générés</span>
  </div>
  <div class="stat-card">
    <strong><%= number_with_delimiter(@usage_events.sum(:total_tokens)) %></strong>
    <span>Tokens au total</span>
  </div>
</section>

<section class="grid grid-two">
  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Limites mensuelles</h2>
      <div class="detail-list">
        <div class="detail-row">
          <span class="detail-label">Réponses IA</span>
          <span>
            <%= current_account.monthly_message_limit.present? ? "#{number_with_delimiter(@message_limit_remaining)} restantes / #{number_with_delimiter(current_account.monthly_message_limit)}" : "Illimité" %>
          </span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Tokens au total</span>
          <span>
            <%= current_account.monthly_token_limit.present? ? "#{number_with_delimiter(@token_limit_remaining)} restants / #{number_with_delimiter(current_account.monthly_token_limit)}" : "Illimité" %>
          </span>
        </div>
      </div>
    </div>
  </article>
</section>

<section class="grid grid-two">
  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Utilisation par agent</h2>
      <% if @usage_by_agent.present? %>
        <div class="usage-agent-list">
          <% @usage_by_agent.each do |agent_name, event_count| %>
            <div class="detail-row">
              <span class="detail-label"><%= agent_name %></span>
              <span>
                <%= pluralize(event_count, "événement") %>
                · <%= number_with_delimiter(@tokens_by_agent[agent_name].to_i) %> tokens
              </span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="muted">Aucune utilisation suivie ce mois-ci.</p>
      <% end %>
    </div>
  </article>

  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Répartition des événements</h2>
      <div class="detail-list">
        <div class="detail-row">
          <span class="detail-label">Messages</span>
          <span><%= pluralize(@message_usage.count, "événement") %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Embeddings</span>
          <span><%= pluralize(@embedding_usage.count, "événement") %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Événements estimés</span>
          <span><%= @usage_events.where("metadata ->> 'estimated_tokens' = ?", "true").count %></span>
        </div>
      </div>
    </div>
  </article>
</section>

<section class="table-wrap usage-events-table">
  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>Agent</th>
        <th>Type</th>
        <th>Modèle</th>
        <th>Entrée</th>
        <th>Sortie</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <% if @recent_usage_events.present? %>
        <% @recent_usage_events.each do |event| %>
          <tr>
            <td><%= l(event.created_at, format: :short) %></td>
            <td><%= event.agent.name %></td>
            <td><span class="badge"><%= event.event_type %></span></td>
            <td><%= event.model.presence || "Inconnu" %></td>
            <td><%= number_with_delimiter(event.input_tokens) %></td>
            <td><%= number_with_delimiter(event.output_tokens) %></td>
            <td><%= number_with_delimiter(event.total_tokens) %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="7" class="empty-state">Aucun événement d'utilisation pour le moment.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
