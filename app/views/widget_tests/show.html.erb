<!DOCTYPE html>
<html lang="fr">
  <head>
    <title>Test du widget</title>
  </head>
  <body>
    <h1>Page cliente de test</h1>

    <% if @agent.present? %>
      <p>
        Agent testé :
        <strong><%= @agent.name %></strong>
        (<code><%= @agent.public_token %></code>)
      </p>

      <script src="http://localhost:3000/widget.js" data-agent-token="<%= @agent.public_token %>"></script>
    <% else %>
      <p>Aucun agent trouvé pour ce jeton. Lancez <code>bin/rails db:seed</code> ou utilisez un jeton valide.</p>
    <% end %>
  </body>
</html>
