<!DOCTYPE html>
<html lang="fr">
  <head>
    <title>Studio 47</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= favicon_link_tag "head-icon.png", type: "image/png" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="backoffice-shell">
    <aside class="app-sidebar">
      <%= link_to root_path, class: "app-brand" do %>
        <%= image_tag "brand-logo.png", class: "app-brand-logo", alt: "Chatbot SaaS" %>
        <span class="app-brand-name">
          <strong>Studio 47</strong>
          <small>Admin</small>
        </span>
      <% end %>

      <nav class="app-nav" aria-label="Navigation de l'administration">
        <%= link_to "Agents", agents_path, class: "app-nav-link" %>
        <%= link_to "Utilisation", usage_path, class: "app-nav-link" %>
        <% if current_user&.platform_admin? %>
          <%= link_to "Clients", admin_usage_path, class: "app-nav-link" %>
        <% end %>
      </nav>
    </aside>

    <div class="app-frame">
      <header class="topbar">
        <div class="app-container topbar-inner">
          <div>
            <span class="topbar-kicker">Espace de travail</span>
            <strong><%= current_account&.name || "Console d'exploitation IA" %></strong>
          </div>
          <div class="actions">
            <% if user_signed_in? %>
              <span class="topbar-status"><%= current_user.email %></span>
              <%= button_to "Se déconnecter", destroy_user_session_path, method: :delete, class: "btn" %>
            <% else %>
              <%= link_to "Se connecter", new_user_session_path, class: "btn btn-primary" %>
            <% end %>
          </div>
        </div>
      </header>

      <% if notice.present? || alert.present? %>
        <div class="flash-region" aria-live="polite" aria-atomic="true">
          <% if notice.present? %>
            <div class="flash flash-notice" data-controller="flash" data-flash-auto-dismiss-value="3000">
              <span><%= notice %></span>
              <button class="flash-close" type="button" aria-label="Fermer la notification" data-action="flash#close">&times;</button>
            </div>
          <% end %>

          <% if alert.present? %>
            <div class="flash flash-alert" data-controller="flash" data-flash-auto-dismiss-value="3000">
              <span><%= alert %></span>
              <button class="flash-close" type="button" aria-label="Fermer la notification" data-action="flash#close">&times;</button>
            </div>
          <% end %>
        </div>
      <% end %>

      <main class="app-container app-main">
        <%= yield %>
      </main>

      <footer class="app-footer">
        <div class="app-container app-footer-inner">
          <span>&copy; <%= Time.current.year %> Studio 47</span>
          <nav aria-label="Informations légales">
            <%= link_to "Mentions légales", legal_notice_path %>
            <%= link_to "Confidentialité", privacy_path %>
            <%= link_to "CGU", terms_path %>
            <%= link_to "Contact", contact_path %>
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>
