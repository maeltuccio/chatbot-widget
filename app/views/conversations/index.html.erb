<section class="page-header">
  <div>
    <span class="eyebrow">Conversations</span>
    <h1 class="page-title"><%= @agent.name %></h1>
  </div>

  <div class="actions">
    <%= link_to "Retour à l'agent", agent_path(@agent), class: "btn" %>
  </div>
</section>

<section class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Token</th>
        <th>Messages</th>
        <th>Dernier message</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @conversations.each do |conversation| %>
        <tr>
          <td data-label="Token"><code><%= conversation.public_token %></code></td>
          <td data-label="Messages"><%= conversation.messages.size %></td>
          <td data-label="Dernier message"><%= l((conversation.last_message_at || conversation.created_at), format: :short) %></td>
          <td data-label="Actions"><%= link_to "Ouvrir", agent_conversation_path(@agent, conversation), class: "btn" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
