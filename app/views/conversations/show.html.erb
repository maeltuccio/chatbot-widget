<section class="page-header">
  <div>
    <span class="eyebrow">Conversation</span>
    <h1 class="page-title"><%= @conversation.public_token.first(10) %>...</h1>
  </div>

  <div class="actions">
    <%= link_to "Retour aux conversations", agent_conversations_path(@agent), class: "btn" %>
    <%= link_to "Retour à l'agent", agent_path(@agent), class: "btn" %>
  </div>
</section>

<section class="grid">
  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Détails</h2>
      <div class="detail-list">
        <div class="detail-row">
          <span class="detail-label">Agent</span>
          <span><%= @agent.name %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Token</span>
          <span><code><%= @conversation.public_token %></code></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Messages</span>
          <span><%= @messages.size %></span>
        </div>
      </div>
    </div>
  </article>

  <% if @conversation.summary.present? %>
    <article class="card">
      <div class="card-body">
        <h2 class="section-title">Résumé</h2>
        <pre><%= @conversation.summary %></pre>
      </div>
    </article>
  <% end %>

  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Messages</h2>
      <div class="message-list">
        <% @messages.each do |message| %>
          <article class="message-card">
            <div class="message-meta">
              <span class="badge <%= message.role == "assistant" ? "badge-success" : "" %>"><%= message_role_label(message.role) %></span>
              <span class="muted"><%= l(message.created_at, format: :short) %></span>
            </div>
            <pre><%= message.content %></pre>
          </article>
        <% end %>
      </div>
    </div>
  </article>
</section>
