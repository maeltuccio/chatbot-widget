<section class="page-header">
  <div>
    <span class="eyebrow">Edit</span>
    <h1 class="page-title"><%= @agent.name %></h1>
    <p class="page-description">Update behavior, knowledge-facing instructions and widget settings.</p>
  </div>

  <div class="actions">
    <%= link_to "Open agent", agent_path(@agent), class: "btn" %>
    <%= link_to "Back", agents_path, class: "btn" %>
  </div>
</section>

<section class="agent-editor-layout" data-controller="agent-playground agent-template">
  <div class="agent-editor-form">
    <%= render "form", agent: @agent %>
  </div>

  <aside class="card agent-editor-playground">
    <div class="card-body">
      <h2 class="section-title">Playground</h2>
      <iframe
        class="chatbot-playground-frame"
        src="<%= playground_agent_path(@agent) %>"
        title="Chatbot playground for <%= @agent.name %>"
        data-agent-playground-target="frame"></iframe>
      <div class="actions chatbot-playground-actions">
        <button type="button" class="btn btn-primary" data-action="agent-playground#refresh">
          Update chatbot preview
        </button>
      </div>
      <p class="field-hint" data-agent-playground-target="status" role="status" aria-live="polite"></p>
    </div>
  </aside>
</section>
