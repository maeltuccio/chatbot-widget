<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= @agent.name %> playground</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <style>
      * {
        box-sizing: border-box;
      }

      html {
        min-height: 100%;
        background: #101827;
      }

      body {
        display: grid;
        place-items: center;
        min-height: 100vh;
        margin: 0;
        overflow: hidden;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          linear-gradient(120deg, rgba(34, 211, 238, 0.86), rgba(139, 92, 246, 0.82), rgba(244, 114, 182, 0.76), rgba(20, 184, 166, 0.82));
        background-size: 300% 300%;
        animation: playground-gradient-shift 12s ease-in-out infinite;
      }

      body::before {
        position: fixed;
        inset: 0;
        content: "";
        background:
          linear-gradient(rgba(255, 255, 255, 0.18) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.14) 1px, transparent 1px);
        background-size: 44px 44px;
        mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.82), transparent 88%);
        pointer-events: none;
      }

      @keyframes playground-gradient-shift {
        0% {
          background-position: 0% 50%;
        }

        50% {
          background-position: 100% 50%;
        }

        100% {
          background-position: 0% 50%;
        }
      }

      #chatbot-saas-widget {
        position: static !important;
      }

      #chatbot-saas-widget .chatbot-saas-panel-open {
        max-height: calc(100vh - 40px);
      }
    </style>
  </head>

  <body>
    <script src="/widget.js" data-agent-token="<%= @agent.public_token %>" data-open="true"></script>
  </body>
</html>
