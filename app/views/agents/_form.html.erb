<% if agent.errors.any? %>
  <div class="error-box">
    <strong><%= pluralize(agent.errors.count, "erreur") %> empêche(nt) l'enregistrement de cet agent.</strong>
    <ul>
      <% agent.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<section class="card form-card">
  <div class="card-body">
    <%= form_with(model: agent, url: agent.persisted? ? edit_agent_path(agent) : agents_path, method: agent.persisted? ? :patch : :post, class: "form-grid", data: { turbo: false, agent_playground_target: agent.persisted? ? "form" : nil }) do |form| %>
      <div class="field">
        <%= form.label :name %>
        <%= form.text_field :name %>
      </div>

      <div class="field">
        <%= form.label :welcome_message %>
        <%= form.text_area :welcome_message, rows: 3 %>
      </div>

      <div class="field">
        <%= form.label :tone %>
        <% tone_options = [
          "Amical et concis",
          "Professionnel et rassurant",
          "Chaleureux et conversationnel",
          "Expert et précis",
          "Direct et orienté vente",
          "Calme et aidant",
          "Premium et soigné"
        ] %>
        <%= select_tag :tone_template,
          options_for_select(tone_options, agent.tone),
          include_blank: "Choisir un ton prédéfini",
          data: {
            action: "agent-template#select",
            agent_template_target: "select"
          } %>
        <%= form.text_field :tone,
          placeholder: "Ou écrire un ton personnalisé",
          data: {
            agent_template_target: "input"
          } %>
        <p class="field-hint">Choisissez un ton, puis adaptez-le si le chatbot a besoin d'une voix plus précise.</p>
      </div>

      <div class="field">
        <%= form.label :primary_goal %>
        <% primary_goal_options = [
          "Répondre aux questions des clients",
          "Qualifier les prospects et collecter leurs coordonnées",
          "Recommander le bon service ou la bonne offre",
          "Aider les visiteurs à réserver un rendez-vous",
          "Accompagner les clients après achat",
          "Expliquer les prix et les offres",
          "Guider les visiteurs pendant l'onboarding"
        ] %>
        <%= select_tag :primary_goal_template,
          options_for_select(primary_goal_options, agent.primary_goal),
          include_blank: "Choisir un objectif prédéfini",
          data: {
            action: "agent-template#select",
            agent_template_target: "select"
          } %>
        <%= form.text_field :primary_goal,
          placeholder: "Ou écrire un objectif personnalisé",
          data: {
            agent_template_target: "input"
          } %>
        <p class="field-hint">Choisissez un objectif, puis adaptez le texte si nécessaire.</p>
      </div>

      <div class="field">
        <%= form.label :system_prompt %>
        <%= form.text_area :system_prompt, rows: 10 %>
      </div>

      <fieldset class="form-grid">
        <legend>Personnalisation du widget</legend>

        <div class="field">
          <%= form.label :widget_title %>
          <%= form.text_field :widget_title %>
        </div>

        <div class="check-field">
          <%= form.check_box :widget_show_title %>
          <%= form.label :widget_show_title, "Afficher le nom du chatbot" %>
        </div>

        <div class="field">
          <%= form.label :widget_primary_color %>
          <%= form.color_field :widget_primary_color, value: agent.widget_primary_color.presence || "#111827" %>
        </div>

        <div class="field">
          <%= form.label :widget_theme, "Thème du widget" %>
          <div class="theme-options">
            <% [
              ["Verre", "glass", "Panneau translucide avec flou doux"],
              ["Clair", "light", "Widget de support blanc et lisible"],
              ["Sombre", "dark", "Interface sombre à fort contraste"]
            ].each do |label, value, description| %>
              <label class="theme-option">
                <%= form.radio_button :widget_theme,
                  value,
                  checked: (agent.widget_theme.presence || "glass") == value,
                  data: { action: "agent-playground#refresh" } %>
                <span class="theme-option-preview theme-option-preview-<%= value %>">
                  <span class="theme-option-header"></span>
                  <span class="theme-option-message theme-option-message-assistant"></span>
                  <span class="theme-option-message theme-option-message-visitor"></span>
                  <span class="theme-option-input"></span>
                </span>
                <span>
                  <strong><%= label %></strong>
                  <small><%= description %></small>
                </span>
              </label>
            <% end %>
          </div>
        </div>

        <div class="field">
          <%= form.label :widget_position %>
          <%= form.select :widget_position, widget_position_options %>
        </div>

        <div class="field">
          <%= form.label :widget_send_label %>
          <%= form.text_field :widget_send_label %>
        </div>

        <div class="field">
          <%= form.label :widget_placeholder %>
          <%= form.text_field :widget_placeholder %>
        </div>

        <div class="field">
          <%= form.label :allowed_origins, "Domaines autorisés pour le widget" %>
          <%= form.text_area :allowed_origins, rows: 3, placeholder: "https://example.com\nhttps://www.example.com" %>
          <p class="field-hint">Un domaine par ligne. Laissez vide uniquement en développement local.</p>
        </div>
      </fieldset>

      <div class="check-field">
        <%= form.check_box :active %>
        <%= form.label :active %>
      </div>

      <div class="actions">
        <%= form.submit %>
      </div>
    <% end %>
  </div>
</section>
