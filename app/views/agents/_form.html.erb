<% if agent.errors.any? %>
  <div class="error-box">
    <strong><%= pluralize(agent.errors.count, "error") %> prevented this agent from being saved.</strong>
    <ul>
      <% agent.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<section class="card form-card">
  <div class="card-body">
    <%= form_with(model: agent, url: agent.persisted? ? edit_agent_path(agent) : agents_path, method: agent.persisted? ? :patch : :post, class: "form-grid", data: { turbo: false, agent_playground_target: agent.persisted? ? "form" : nil }) do |form| %>
      <div class="field">
        <%= form.label :name %>
        <%= form.text_field :name %>
      </div>

      <div class="field">
        <%= form.label :welcome_message %>
        <%= form.text_area :welcome_message, rows: 3 %>
      </div>

      <div class="field">
        <%= form.label :tone %>
        <% tone_options = [
          "Friendly and concise",
          "Professional and reassuring",
          "Warm and conversational",
          "Expert and precise",
          "Direct and sales-focused",
          "Calm and supportive",
          "Premium and polished"
        ] %>
        <%= select_tag :tone_template,
          options_for_select(tone_options, agent.tone),
          include_blank: "Choose a predefined tone",
          data: {
            action: "agent-template#select",
            agent_template_target: "select"
          } %>
        <%= form.text_field :tone,
          placeholder: "Or write a custom tone",
          data: {
            agent_template_target: "input"
          } %>
        <p class="field-hint">Choose a tone, then edit it if the chatbot needs a more specific voice.</p>
      </div>

      <div class="field">
        <%= form.label :primary_goal %>
        <% primary_goal_options = [
          "Answer customer questions",
          "Qualify leads and collect contact details",
          "Recommend the right service or offer",
          "Help visitors book an appointment",
          "Support customers after purchase",
          "Explain pricing and plans",
          "Guide visitors through onboarding"
        ] %>
        <%= select_tag :primary_goal_template,
          options_for_select(primary_goal_options, agent.primary_goal),
          include_blank: "Choose a predefined goal",
          data: {
            action: "agent-template#select",
            agent_template_target: "select"
          } %>
        <%= form.text_field :primary_goal,
          placeholder: "Or write a custom goal",
          data: {
            agent_template_target: "input"
          } %>
        <p class="field-hint">Choose a goal, then edit the text if you need something more specific.</p>
      </div>

      <div class="field">
        <%= form.label :system_prompt %>
        <%= form.text_area :system_prompt, rows: 10 %>
      </div>

      <fieldset class="form-grid">
        <legend>Widget customization</legend>

        <div class="field">
          <%= form.label :widget_title %>
          <%= form.text_field :widget_title %>
        </div>

        <div class="check-field">
          <%= form.check_box :widget_show_title %>
          <%= form.label :widget_show_title, "Show chatbot name" %>
        </div>

        <div class="field">
          <%= form.label :widget_primary_color %>
          <%= form.color_field :widget_primary_color, value: agent.widget_primary_color.presence || "#111827" %>
        </div>

        <div class="field">
          <%= form.label :widget_theme, "Widget layout" %>
          <div class="theme-options">
            <% [
              ["Glass", "glass", "Translucent panel with soft blur"],
              ["Light", "light", "Clean white support widget"],
              ["Dark", "dark", "High contrast dark interface"]
            ].each do |label, value, description| %>
              <label class="theme-option">
                <%= form.radio_button :widget_theme,
                  value,
                  checked: (agent.widget_theme.presence || "glass") == value,
                  data: { action: "agent-playground#refresh" } %>
                <span class="theme-option-preview theme-option-preview-<%= value %>">
                  <span class="theme-option-header"></span>
                  <span class="theme-option-message theme-option-message-assistant"></span>
                  <span class="theme-option-message theme-option-message-visitor"></span>
                  <span class="theme-option-input"></span>
                </span>
                <span>
                  <strong><%= label %></strong>
                  <small><%= description %></small>
                </span>
              </label>
            <% end %>
          </div>
        </div>

        <div class="field">
          <%= form.label :widget_position %>
          <%= form.select :widget_position, [["Bottom right", "bottom_right"], ["Bottom left", "bottom_left"]] %>
        </div>

        <div class="field">
          <%= form.label :widget_send_label %>
          <%= form.text_field :widget_send_label %>
        </div>

        <div class="field">
          <%= form.label :widget_placeholder %>
          <%= form.text_field :widget_placeholder %>
        </div>

        <div class="field">
          <%= form.label :allowed_origins, "Allowed widget domains" %>
          <%= form.text_area :allowed_origins, rows: 3, placeholder: "https://example.com\nhttps://www.example.com" %>
          <p class="field-hint">One domain per line. Leave blank only for local development.</p>
        </div>
      </fieldset>

      <div class="check-field">
        <%= form.check_box :active %>
        <%= form.label :active %>
      </div>

      <div class="actions">
        <%= form.submit %>
      </div>
    <% end %>
  </div>
</section>
