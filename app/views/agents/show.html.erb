<section class="page-header">
  <div>
    <span class="eyebrow">Agent</span>
    <h1 class="page-title"><%= @agent.name %></h1>
    <p class="page-description"><%= @agent.primary_goal.presence || "No primary goal configured yet." %></p>
  </div>

  <div class="actions">
    <%= link_to "Conversations", agent_conversations_path(@agent), class: "btn" %>
    <%= link_to "Knowledge", agent_knowledge_sources_path(@agent), class: "btn" %>
    <%= link_to "Webflow", agent_webflow_connection_path(@agent), class: "btn" %>
    <%= link_to "Edit", edit_agent_path(@agent), class: "btn btn-primary" %>
  </div>
</section>

<section class="stats-grid">
  <div class="stat-card">
    <strong><%= @agent.conversations.count %></strong>
    <span>Conversations</span>
  </div>
  <div class="stat-card">
    <strong><%= @agent.knowledge_sources.count %></strong>
    <span>Knowledge sources</span>
  </div>
  <div class="stat-card">
    <strong><%= @agent.active? ? "Live" : "Off" %></strong>
    <span>Widget status</span>
  </div>
</section>

<section class="grid grid-two">
  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Configuration</h2>
      <div class="detail-list">
        <div class="detail-row">
          <span class="detail-label">Public token</span>
          <span><code><%= @agent.public_token %></code></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Welcome</span>
          <span><%= @agent.welcome_message %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Tone</span>
          <span><%= @agent.tone.presence || "Not set" %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Status</span>
          <span class="badge <%= @agent.active? ? "badge-success" : "badge-warning" %>"><%= @agent.active? ? "Active" : "Inactive" %></span>
        </div>
      </div>
    </div>
  </article>

  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Widget</h2>
      <div class="detail-list">
        <div class="detail-row">
          <span class="detail-label">Title</span>
          <span><%= @agent.widget_title %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Show title</span>
          <span><%= @agent.widget_show_title? ? "Yes" : "No" %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Primary color</span>
          <span><%= @agent.widget_primary_color %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Position</span>
          <span><%= @agent.widget_position %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Layout</span>
          <span><%= @agent.widget_theme %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Placeholder</span>
          <span><%= @agent.widget_placeholder %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Allowed domains</span>
          <span><%= @agent.allowed_origin_list.presence&.join(", ") || "Development only" %></span>
        </div>
      </div>
    </div>
  </article>
</section>

<section class="grid">
  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Webflow CMS</h2>
      <% if @agent.webflow_connection.present? %>
        <% connection = @agent.webflow_connection %>
        <div class="detail-list">
          <div class="detail-row">
            <span class="detail-label">Status</span>
            <span class="badge <%= connection.configured? ? "badge-success" : "badge-warning" %>"><%= connection.status %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Collection</span>
            <span><%= connection.collection_name.presence || connection.collection_id.presence || "Not selected" %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Last sync</span>
            <span><%= connection.last_synced_at.present? ? l(connection.last_synced_at, format: :short) : "Never" %></span>
          </div>
        </div>
        <div class="actions form-actions">
          <%= link_to "Configure Webflow", agent_webflow_connection_path(@agent), class: "btn" %>
          <%= button_to "Sync now", sync_agent_webflow_connection_path(@agent), method: :post, class: "btn btn-primary", disabled: !connection.syncable? %>
        </div>
      <% else %>
        <p class="muted">Connect this agent to a Webflow CMS collection and sync the services into its knowledge base.</p>
        <%= link_to "Connect Webflow", connect_agent_webflow_connection_path(@agent), class: "btn btn-primary" %>
      <% end %>
    </div>
  </article>

  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Integration script</h2>
      <pre class="code-block"><code>&lt;script src="http://localhost:3000/widget.js" data-agent-token="<%= @agent.public_token %>"&gt;&lt;/script&gt;</code></pre>
    </div>
  </article>

  <article class="card">
    <div class="card-body">
      <h2 class="section-title">System prompt</h2>
      <pre><%= @agent.system_prompt %></pre>
    </div>
  </article>

  <div class="actions">
    <%= link_to "Back to agents", agents_path, class: "btn" %>
    <%= button_to "Delete agent",
      agent_path(@agent),
      method: :delete,
      class: "danger-button",
      form: { data: { turbo_confirm: "Delete #{@agent.name}? This will also delete its conversations and knowledge sources." } } %>
  </div>
</section>
