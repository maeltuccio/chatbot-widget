<section class="page-header">
  <div>
    <span class="eyebrow">Agent</span>
    <h1 class="page-title"><%= @agent.name %></h1>
    <p class="page-description"><%= @agent.primary_goal.presence || "Aucun objectif principal configuré pour le moment." %></p>
  </div>

  <div class="actions">
    <%= link_to "Conversations", agent_conversations_path(@agent), class: "btn" %>
    <%= link_to "Connaissance", agent_knowledge_sources_path(@agent), class: "btn" %>
    <%= link_to "Webflow", agent_webflow_connection_path(@agent), class: "btn" %>
    <%= link_to "Modifier", edit_agent_path(@agent), class: "btn btn-primary" %>
  </div>
</section>

<section class="stats-grid">
  <div class="stat-card">
    <strong><%= @agent.conversations.count %></strong>
    <span>Conversations</span>
  </div>
  <div class="stat-card">
    <strong><%= @agent.knowledge_sources.count %></strong>
    <span>Sources de connaissance</span>
  </div>
  <div class="stat-card">
    <strong><%= widget_status_label(@agent) %></strong>
    <span>Statut du widget</span>
  </div>
</section>

<section class="grid grid-two">
  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Configuration</h2>
      <div class="detail-list">
        <div class="detail-row">
          <span class="detail-label">Jeton public</span>
          <span><code><%= @agent.public_token %></code></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Message d'accueil</span>
          <span><%= @agent.welcome_message %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Ton</span>
          <span><%= @agent.tone.presence || "Non défini" %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Statut</span>
          <span class="badge <%= @agent.active? ? "badge-success" : "badge-warning" %>"><%= agent_status_label(@agent) %></span>
        </div>
      </div>
    </div>
  </article>

  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Widget</h2>
      <div class="detail-list">
        <div class="detail-row">
          <span class="detail-label">Titre</span>
          <span><%= @agent.widget_title %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Afficher le titre</span>
          <span><%= yes_no_label(@agent.widget_show_title?) %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Couleur principale</span>
          <span><%= @agent.widget_primary_color %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Position</span>
          <span><%= @agent.widget_position %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Thème</span>
          <span><%= widget_theme_label(@agent.widget_theme) %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Placeholder</span>
          <span><%= @agent.widget_placeholder %></span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Domaines autorisés</span>
          <span><%= @agent.allowed_origin_list.presence&.join(", ") || "Développement uniquement" %></span>
        </div>
      </div>
    </div>
  </article>
</section>

<section class="grid">
  <article class="card">
    <div class="card-body">
      <h2 class="section-title">CMS Webflow</h2>
      <% if @agent.webflow_connection.present? %>
        <% connection = @agent.webflow_connection %>
        <div class="detail-list">
          <div class="detail-row">
            <span class="detail-label">Statut</span>
            <span class="badge <%= connection.configured? ? "badge-success" : "badge-warning" %>"><%= connection_status_label(connection.status) %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Collection</span>
            <span><%= connection.collection_name.presence || connection.collection_id.presence || "Non sélectionnée" %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Dernière synchro</span>
            <span><%= connection.last_synced_at.present? ? l(connection.last_synced_at, format: :short) : "Jamais" %></span>
          </div>
        </div>
        <div class="actions form-actions">
          <%= link_to "Configurer Webflow", agent_webflow_connection_path(@agent), class: "btn" %>
          <%= button_to "Synchroniser", sync_agent_webflow_connection_path(@agent), method: :post, class: "btn btn-primary", disabled: !connection.syncable? %>
        </div>
      <% else %>
        <p class="muted">Connectez cet agent à une collection CMS Webflow et synchronisez les services dans sa base de connaissance.</p>
        <%= link_to "Connecter Webflow", connect_agent_webflow_connection_path(@agent), class: "btn btn-primary" %>
      <% end %>
    </div>
  </article>

  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Script d'intégration</h2>
      <% widget_host = ENV["APP_HOST"].presence || request.base_url %>
      <pre class="code-block"><code>&lt;script src="<%= "#{widget_host.chomp("/")}/widget.js" %>" data-agent-token="<%= @agent.public_token %>"&gt;&lt;/script&gt;</code></pre>
    </div>
  </article>

  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Prompt système</h2>
      <pre><%= @agent.system_prompt %></pre>
    </div>
  </article>

  <div class="actions">
    <%= link_to "Retour aux agents", agents_path, class: "btn" %>
    <%= button_to "Supprimer l'agent",
      agent_path(@agent),
      method: :delete,
      class: "danger-button",
      form: { data: { turbo_confirm: "Supprimer #{@agent.name} ? Cela supprimera aussi ses conversations et ses sources de connaissance." } } %>
  </div>
</section>
