<section class="page-header">
  <div>
    <span class="eyebrow">Connaissance</span>
    <h1 class="page-title"><%= @agent.name %></h1>
  </div>

  <div class="actions">
    <%= link_to "Nouvelle source", new_agent_knowledge_source_path(@agent), class: "btn btn-primary" %>
    <%= link_to "Retour à l'agent", agent_path(@agent), class: "btn" %>
  </div>
</section>

<section class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Titre</th>
        <th>Type</th>
        <th>Statut</th>
        <th>Morceaux</th>
        <th>Mis à jour</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @knowledge_sources.each do |knowledge_source| %>
        <tr>
          <td data-label="Titre">
            <span class="name-cell">
              <strong><%= knowledge_source.title %></strong>
              <small><%= truncate(knowledge_source.raw_content.to_s, length: 84) %></small>
            </span>
          </td>
          <td data-label="Type"><%= source_type_label(knowledge_source.source_type) %></td>
          <td data-label="Statut">
            <span class="badge <%= knowledge_source.status == "ready" ? "badge-success" : "badge-warning" %>">
              <%= source_status_label(knowledge_source.status) %>
            </span>
          </td>
          <td data-label="Morceaux"><%= knowledge_source.knowledge_chunks.size %></td>
          <td data-label="Mis à jour"><%= l(knowledge_source.updated_at, format: :short) %></td>
          <td data-label="Actions">
            <div class="actions">
              <%= link_to "Ouvrir", agent_knowledge_source_path(@agent, knowledge_source), class: "btn" %>
              <%= link_to "Modifier", edit_agent_knowledge_source_path(@agent, knowledge_source), class: "btn" %>
              <%= button_to "Supprimer",
                agent_knowledge_source_path(@agent, knowledge_source),
                method: :delete,
                class: "danger-button",
                form: { data: { turbo_confirm: "Supprimer cette source de connaissance ?" } } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
