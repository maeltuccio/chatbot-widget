<% if knowledge_source.errors.any? %>
  <div class="error-box">
    <strong><%= pluralize(knowledge_source.errors.count, "erreur") %> empêche(nt) l'enregistrement de cette source.</strong>
    <ul>
      <% knowledge_source.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<section class="card form-card">
  <div class="card-body">
    <%= form_with(model: [agent, knowledge_source], class: "form-grid") do |form| %>
      <div class="field">
        <%= form.label :title %>
        <%= form.text_field :title %>
      </div>

      <div class="field">
        <%= form.label :raw_content, "Contenu" %>
        <%= form.text_area :raw_content, rows: 18 %>
        <p class="field-hint">Le contenu est découpé automatiquement après l'enregistrement.</p>
      </div>

      <div class="actions">
        <%= form.submit %>
      </div>
    <% end %>
  </div>
</section>
