<section class="page-header">
  <div>
    <span class="eyebrow">Source de connaissance</span>
    <h1 class="page-title"><%= @knowledge_source.title %></h1>
    <p class="page-description">Consultez le contenu brut et les morceaux disponibles pour la recherche.</p>
  </div>

  <div class="actions">
    <%= link_to "Modifier", edit_agent_knowledge_source_path(@agent, @knowledge_source), class: "btn btn-primary" %>
    <%= link_to "Retour", agent_knowledge_sources_path(@agent), class: "btn" %>
  </div>
</section>

<section class="stats-grid">
  <div class="stat-card">
    <strong><%= source_status_label(@knowledge_source.status) %></strong>
    <span>Statut</span>
  </div>
  <div class="stat-card">
    <strong><%= @knowledge_chunks.size %></strong>
    <span>Morceaux</span>
  </div>
  <div class="stat-card">
    <strong><%= source_type_label(@knowledge_source.source_type) %></strong>
    <span>Type de source</span>
  </div>
</section>

<section class="grid">
  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Contenu</h2>
      <pre><%= @knowledge_source.raw_content %></pre>
    </div>
  </article>

  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Morceaux</h2>

      <% if @knowledge_chunks.any? %>
        <div class="message-list">
          <% @knowledge_chunks.each do |chunk| %>
            <article class="message-card">
              <div class="message-meta">
                <strong>Morceau <%= chunk.position + 1 %></strong>
                <span class="muted"><%= chunk.embedding_model %></span>
              </div>
              <pre><%= chunk.content %></pre>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <strong>Aucun morceau pour le moment</strong>
          <p>Enregistrez la source pour générer les morceaux de recherche.</p>
        </div>
      <% end %>
    </div>
  </article>
</section>
