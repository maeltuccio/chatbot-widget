<section class="page-header">
  <div>
    <span class="eyebrow">Knowledge source</span>
    <h1 class="page-title"><%= @knowledge_source.title %></h1>
    <p class="page-description">Review raw source content and the chunks available to retrieval.</p>
  </div>

  <div class="actions">
    <%= link_to "Edit", edit_agent_knowledge_source_path(@agent, @knowledge_source), class: "btn btn-primary" %>
    <%= link_to "Back", agent_knowledge_sources_path(@agent), class: "btn" %>
  </div>
</section>

<section class="stats-grid">
  <div class="stat-card">
    <strong><%= @knowledge_source.status %></strong>
    <span>Status</span>
  </div>
  <div class="stat-card">
    <strong><%= @knowledge_chunks.size %></strong>
    <span>Chunks</span>
  </div>
  <div class="stat-card">
    <strong><%= @knowledge_source.source_type %></strong>
    <span>Source type</span>
  </div>
</section>

<section class="grid">
  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Content</h2>
      <pre><%= @knowledge_source.raw_content %></pre>
    </div>
  </article>

  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Chunks</h2>

      <% if @knowledge_chunks.any? %>
        <div class="message-list">
          <% @knowledge_chunks.each do |chunk| %>
            <article class="message-card">
              <div class="message-meta">
                <strong>Chunk <%= chunk.position + 1 %></strong>
                <span class="muted"><%= chunk.embedding_model %></span>
              </div>
              <pre><%= chunk.content %></pre>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <strong>No chunks yet</strong>
          <p>Save the source to generate retrieval chunks.</p>
        </div>
      <% end %>
    </div>
  </article>
</section>
