<section class="page-header">
  <div>
    <span class="eyebrow">Intégration</span>
    <h1 class="page-title">Webflow</h1>
  </div>

  <div class="actions">
    <%= link_to "Retour à l'agent", agent_path(@agent), class: "btn" %>
  </div>
</section>

<section class="grid grid-two">
  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Connexion</h2>

      <% if @connection.present? %>
        <div class="detail-list">
          <div class="detail-row">
            <span class="detail-label">Statut</span>
            <span class="badge <%= @connection.configured? ? "badge-success" : "badge-warning" %>"><%= connection_status_label(@connection.status) %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Site</span>
            <span><%= @connection.site_name.presence || @connection.site_id.presence || "Non sélectionné" %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Collection</span>
            <span><%= @connection.collection_name.presence || @connection.collection_id.presence || "Non sélectionnée" %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Dernière synchro</span>
            <span><%= @connection.last_synced_at.present? ? l(@connection.last_synced_at, format: :short) : "Jamais" %></span>
          </div>
        </div>

        <div class="actions form-actions">
          <%= button_to "Synchroniser", sync_agent_webflow_connection_path(@agent), method: :post, class: "btn btn-primary", disabled: !@connection.syncable? %>
          <%= button_to "Déconnecter", agent_webflow_connection_path(@agent), method: :delete, class: "danger-button", form: { data: { turbo_confirm: "Déconnecter Webflow de cet agent ?" } } %>
        </div>
      <% else %>
        <p class="muted">Webflow n'est pas encore connecté.</p>
        <%= link_to "Connecter Webflow", connect_agent_webflow_connection_path(@agent), class: "btn btn-primary" %>
      <% end %>
    </div>
  </article>

  <article class="card">
    <div class="card-body">
      <h2 class="section-title">Collection CMS</h2>

      <% if @connection.present? %>
        <%= form_with(model: @connection, url: agent_webflow_connection_path(@agent), method: :patch, class: "form-grid") do |form| %>
          <div class="field">
            <%= form.label :site_id, "Site Webflow" %>
            <%= form.select :site_id,
              options_for_select(@sites.map { |site| [site["displayName"] || site["name"] || site["id"], site["id"]] }, @connection.site_id),
              { prompt: "Choisir un site" },
              onchange: "this.form.submit()" %>
            <p class="field-hint">Choisissez le site qui contient la collection CMS des services.</p>
          </div>

          <div class="field">
            <%= form.label :collection_id, "Collection de services" %>
            <%= form.select :collection_id,
              options_for_select(@collections.map { |collection| [collection["displayName"] || collection["name"] || collection["slug"] || collection["id"], collection["id"]] }, @connection.collection_id),
              { prompt: @connection.site_id.present? ? "Choisir une collection" : "Choisir d'abord un site" } %>
            <p class="field-hint">Seule cette collection sera importée dans cet agent.</p>
          </div>

          <div class="actions">
            <%= form.submit "Enregistrer la collection", class: "btn btn-primary" %>
          </div>
        <% end %>
      <% else %>
        <p class="muted">Connectez Webflow d'abord, puis choisissez la collection CMS à utiliser comme catalogue de services pour cet agent.</p>
      <% end %>
    </div>
  </article>
</section>
